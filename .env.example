# ============================================================
# ROBOLUTION SPONSORSHIP INTELLIGENCE SYSTEM
# Environment Configuration
# ============================================================

# --- LLM Provider API Keys ---
# Primary: Gemini (Google AI Studio - free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback 1: Groq (free tier)
GROQ_API_KEY=your_groq_api_key_here

# Fallback 2: OpenRouter (free tier models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Processing Settings ---
BATCH_SIZE=5                    # Companies processed concurrently
CHECKPOINT_EVERY=10             # Save progress every N companies
MAX_RETRIES=4                   # Max retries per API call
REQUEST_TIMEOUT=60              # Seconds per request
FORCE_REFRESH=false             # Set true to reprocess cached entries

# --- Model Settings ---
# Gemini model (primary)
GEMINI_MODEL=gemini-2.5-flash

# Groq fallback models (comma-separated, tried in order)
GROQ_MODELS=moonshotai/kimi-k2-instruct,qwen/qwen3-32b

# OpenRouter fallback models (comma-separated, tried in order)
OPENROUTER_MODELS=deepseek/deepseek-chat-v3-0324:free,qwen/qwen3-235b-a22b:free

# --- Cache Settings ---
CACHE_DB=cache/research_cache.db
CACHE_TTL_HOURS=720             # Cache validity in hours (30 days)

# --- Output Settings ---
OUTPUT_RESEARCH=output/research_output.csv
OUTPUT_OUTREACH=output/outreach_output.csv
